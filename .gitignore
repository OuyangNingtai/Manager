```gitignore
# Python cache files
__pycache__/
*.pyc
*.pyo
*.pyd

# Compiled Python files
*.pyc
*.pyo
*.pyd
*.so
*.egg-info/
.eggs/

# Build and distribution directories
build/
dist/
*.egg
*.whl
pip-wheel-metadata/

# Virtual environments
venv/
.venv/
env/
.env/

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
.coverage
htmlcov/
.coverage.*

# Testing
.pytest_cache/
.mypy_cache/
.hypothesis/

# Environment variables
.env
.env.local
*.env
*.env.*
```